// Agent linux-agent
pipeline {
    agent { label 'linux-agent' }
    options {
        timestamps()
    }
    environment {
        BUILD_DIR = 'build'
        PROJECT_DIR = 'led-firmware'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Prepare') {
            steps {
                script {
                    // Try to use a global shared library named 'led-shared' (branch 'main')
                    def usedShared = false
                    try {
                        library 'led-shared@main'
                        if (this.metaClass.respondsTo(this, 'prepareEnvironment')) {
                            echo 'Using shared library: led-shared.prepareEnvironment()'
                            prepareEnvironment(env.PROJECT_DIR)
                            usedShared = true
                        } else {
                            echo 'Shared library loaded but prepareEnvironment() not found.'
                        }
                    } catch (err) {
                        echo "Shared library not available or failed to load: ${err}"
                    }

                    // If shared library was loaded, set flag for other stages
                    if (usedShared) {
                        env.USE_SHARED = 'true'
                    } else {
                        env.USE_SHARED = 'false'
                    }

                    if (!usedShared) {
                        sh '''
                        set -e
                        NEED_INSTALL=0
                        for cmd in cmake clang-format arm-none-eabi-gcc arm-none-eabi-objcopy; do
                            if ! command -v "$cmd" >/dev/null 2>&1; then
                                NEED_INSTALL=1
                            fi
                        done

                        if [ "$NEED_INSTALL" -eq 1 ]; then
                            if command -v sudo >/dev/null 2>&1; then
                                sudo apt-get update
                                sudo DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends cmake clang-format gcc-arm-none-eabi binutils-arm-none-eabi build-essential || true
                            else
                                apt-get update || true
                                DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends cmake clang-format gcc-arm-none-eabi binutils-arm-none-eabi build-essential || true
                            fi
                        else
                            echo "Required tools already installed"
                        fi
                        '''
                    }
                }
            }
        }

        stage('Lint') {
            steps {
                script {
                    if (env.USE_SHARED == 'true' && this.metaClass.respondsTo(this, 'runClangFormat')) {
                        echo 'Using shared library runClangFormat()'
                        runClangFormat(env.PROJECT_DIR, env.BUILD_DIR)
                    } else if (env.USE_SHARED == 'true') {
                        echo 'Shared library loaded but runClangFormat() not found; falling back to inline'
                        sh '''
                        REPORT_DIR=${PROJECT_DIR}/${BUILD_DIR}
                        mkdir -p "$REPORT_DIR"
                        REPORT="$REPORT_DIR/clang-format-report.txt"
                        echo "Clang-format report generated at: $REPORT" > "$REPORT"
                        if command -v clang-format >/dev/null 2>&1; then
                          find ${PROJECT_DIR}/src ${PROJECT_DIR}/include -type f -name "*.c" -print0 | xargs -0 --no-run-if-empty clang-format --dry-run --Werror >> "$REPORT" || true
                          find ${PROJECT_DIR}/src ${PROJECT_DIR}/include -type f -name "*.h" -print0 | xargs -0 --no-run-if-empty clang-format --dry-run --Werror >> "$REPORT" || true
                        else
                          echo "clang-format not found; skipping lint" >> "$REPORT"
                        fi
                        tail -n +1 "$REPORT" || true
                        '''
                    } else {
                        // No shared lib used; run inline lint
                        sh '''
                        set +e
                        REPORT_DIR=${PROJECT_DIR}/${BUILD_DIR}
                        mkdir -p "$REPORT_DIR"
                        REPORT="$REPORT_DIR/clang-format-report.txt"
                        echo "Clang-format report generated at: $REPORT" > "$REPORT"

                        if command -v clang-format >/dev/null 2>&1; then
                            find ${PROJECT_DIR}/src ${PROJECT_DIR}/include -type f -name "*.c" -print0 | xargs -0 --no-run-if-empty sh -c 'clang-format --dry-run --Werror "$@" 2>&1' sh >> "$REPORT" || true
                            find ${PROJECT_DIR}/src ${PROJECT_DIR}/include -type f -name "*.h" -print0 | xargs -0 --no-run-if-empty sh -c 'clang-format --dry-run --Werror "$@" 2>&1' sh >> "$REPORT" || true
                        else
                            echo "clang-format not found; skipping lint" >> "$REPORT"
                        fi

                        echo "--- clang-format summary ---"
                        tail -n +1 "$REPORT" || true
                        exit 0
                        '''
                    }
                }
            }
        }

        stage('Configure') {
            steps {
                sh '''
                mkdir -p ${PROJECT_DIR}/${BUILD_DIR}
                cd ${PROJECT_DIR}/${BUILD_DIR}
                cmake .. -DCMAKE_TOOLCHAIN_FILE=../arm-gcc-toolchain.cmake
                '''
            }
        }

        stage('Build') {
            steps {
                script {
                    if (env.USE_SHARED == 'true' && this.metaClass.respondsTo(this, 'buildFirmware')) {
                        echo 'Using shared library buildFirmware()'
                        buildFirmware(env.PROJECT_DIR, env.BUILD_DIR)
                    } else {
                        sh '''
                        cd ${PROJECT_DIR}/${BUILD_DIR}
                        cmake --build .
                        '''
                    }
                }
            }
        }

        stage('Verify Artifacts') {
            steps {
                sh 'ls -lh ${PROJECT_DIR}/${BUILD_DIR} || true'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/*.elf,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.hex,${env.PROJECT_DIR}/${env.BUILD_DIR}/*.bin,${env.PROJECT_DIR}/${env.BUILD_DIR}/clang-format-report.txt", allowEmptyArchive: true
            }
        }
    }
    post {
        always {
            echo 'Post-build: archiving clang-format report and printing summary'
            archiveArtifacts artifacts: "${env.PROJECT_DIR}/${env.BUILD_DIR}/clang-format-report.txt", allowEmptyArchive: true
            sh 'echo "--- clang-format report (post) ---"; cat ${PROJECT_DIR}/${BUILD_DIR}/clang-format-report.txt || true'
        }
        success {
            echo 'Build succeeded.'
        }
        failure {
            echo 'Build failed.'
        }
    }
}
